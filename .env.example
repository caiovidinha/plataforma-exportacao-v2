# =========================================================
# PLATAFORMA EXPORTAÇÃO v2 - Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# =========================================================

# ---- Feature Flags -----------------------------------------------
# "true"  → usa dados mockados (sem chamadas à API real)
# "false" → usa a API real definida em NEXT_PUBLIC_API_URL
NEXT_PUBLIC_USE_MOCK_DATA=true

# ---- URLs --------------------------------------------------------
NEXT_PUBLIC_API_URL=https://api.plataforma-exportacao.com.br/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Autenticação ------------------------------------------------
NEXTAUTH_SECRET=your-secret-here
NEXTAUTH_URL=http://localhost:3000

# ---- Integrações Gov.br (Assinatura Digital) ---------------------
NEXT_PUBLIC_GOVBR_CLIENT_ID=
GOVBR_CLIENT_SECRET=
NEXT_PUBLIC_GOVBR_REDIRECT_URI=http://localhost:3000/api/auth/govbr/callback

# ---- SISCOMEX ---------------------------------------------------
SISCOMEX_API_KEY=
SISCOMEX_API_URL=https://siscomex.gov.br/api

# ---- SIGVIG (MAPA) -----------------------------------------------
SIGVIG_API_URL=https://sistemasweb.agricultura.gov.br/sigvig
SIGVIG_API_KEY=

# ---- Analytics ---------------------------------------------------
NEXT_PUBLIC_GA_ID=

# ---- Storage (documentos/PDFs) -----------------------------------
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
